  "catalogPath": "grapher/tourism/2026-01-21/unwto/unwto#same_day_tourist_ratio",
  "descriptionShort": "Same-day trips are those by visitors who arrive and depart within the same day. Tourist trips are those by people who stay overnight. A country with a ratio greater than one has more trips by visitors who leave the same day than those that stay overnight.",
  "type": "float",
  "datasetName": "UN Tourism Statistics Database",
